# ──────────────────────────────────────────────────────────────
# CMA Engagement Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# Supabase — get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude — get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Resend (email) — get from: https://resend.com/api-keys
RESEND_API_KEY=

# Twilio (WhatsApp/SMS) — get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Zeffy Payment Integration — get form ID from your Zeffy dashboard
# Leave as-is to use the Simulate button without a real Zeffy form
NEXT_PUBLIC_ZEFFY_FORM_ID=your-zeffy-form-id-here
ZEFFY_WEBHOOK_SECRET=stub-secret-for-future-hmac-validation
